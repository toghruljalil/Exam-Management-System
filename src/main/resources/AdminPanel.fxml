<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<TabPane prefHeight="700.0" prefWidth="1100.0" styleClass="root-pane" stylesheets="@styles/dashboard.css" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="AdminController">

    <tabs>
        <Tab closable="false" text="Kordinatör Kaydı">
            <content>
                <AnchorPane disable="true" prefWidth="728.0">
                    <children>

                        <!-- Ana içerik -->
                        <ScrollPane fx:id="scrollpane" fitToWidth="true" hbarPolicy="NEVER" layoutY="-3.0" prefHeight="642.0" prefWidth="1100.0" vvalue="1.0">
                            <content>
                                <VBox prefWidth="889.0" spacing="25" styleClass="content-box">
                                    <children>
                                        <VBox prefHeight="26.0" prefWidth="842.0">
                                            <children>
                                                <Text styleClass="header-title" text="👤 Bölüm Kordinatörü Kaydı" wrappingWidth="459.0492858886719" />
                                            </children>
                                        </VBox>

                                        <!-- Derslik Ekle Alanı -->
                                        <VBox prefHeight="122.0" prefWidth="842.0" spacing="10" styleClass="card">
                                            <Text styleClass="section-title" text="Bilgiler" />

                                            <FlowPane hgap="10" vgap="10">
                                                <children>
                                                    <TextField fx:id="bolumAdi" promptText="Bölüm Adı" />
                                                    <TextField fx:id="kordinatorAdi" promptText="Adı" />
                                                    <TextField fx:id="kordinatorSoyadi" promptText="Soyadı" />
                                                    <TextField fx:id="eposta" promptText="Eposta" />
                                                    <TextField fx:id="sifre" promptText="Şifre" />
                                       <Text styleClass="section-title" wrappingWidth="796.0470275878906" />
                                                    <Button fx:id="derslikeklebutton" onAction="#KordinatorEkle" styleClass="accent-button" text="➕ Kordinatör Ekle" />
                                                </children>
                                            </FlowPane>
                                        </VBox>

                                        <!-- Derslikler Tablosu -->
                                        <VBox prefHeight="318.0" prefWidth="884.0" spacing="10" styleClass="card">
                                            <Text styleClass="section-title" text="Kayıltı Kordinatörler" />
                                            <TableView fx:id="kordinatortable" prefHeight="242.0" prefWidth="835.0">
                                                <columns>
                                                    <TableColumn fx:id="bolumadicol" prefWidth="317.59994196891785" text="Bölüm Adı" />
                                                    <TableColumn fx:id="adsoyad" prefWidth="360.00006103515625" text="Adı Soyadı" />
                                                    <TableColumn fx:id="epostacol" prefWidth="301.333251953125" text="Eposta Adresi" />
                                                </columns>
                                    <columnResizePolicy>
                                       <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                            </TableView>
                                        </VBox>
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </children>
                </AnchorPane>
            </content>
        </Tab>
      <Tab closable="false" text="Yönetim Paneli">
         <content>
            <AnchorPane disable="true" prefWidth="728.0">
               <children>
                  <ScrollPane fx:id="scrollpane1" fitToWidth="true" hbarPolicy="NEVER" layoutY="-3.0" prefHeight="642.0" prefWidth="1100.0" vvalue="1.0">
                     <content>
                        <VBox prefWidth="889.0" spacing="25" styleClass="content-box">
                           <children>
                              <VBox prefHeight="26.0" prefWidth="842.0">
                                 <children>
                                    <Text styleClass="header-title" text="🏢 Kayıtlı Bölümler" wrappingWidth="459.0492858886719" />
                                 </children>
                              </VBox>
                              <VBox prefHeight="318.0" prefWidth="884.0" spacing="10" styleClass="card">
                                 <children>
                                    <Text styleClass="section-title" text="Yönetmek İstediğiniz Bölümü Seçin" />
                                    <TableView fx:id="kayitlibolumlertable" prefHeight="242.0" prefWidth="835.0">
                                       <columns>
                                          <TableColumn fx:id="kayitlibolumadi" prefWidth="920.5332915782928" text="Bölüm Adı" />
                                          <TableColumn fx:id="kayitlibolumislem" prefWidth="87.4666748046875" text="İşlem" />
                                       </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                    </TableView>
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                     </content>
                  </ScrollPane>
               </children>
            </AnchorPane>
         </content>
      </Tab>
    </tabs>
</TabPane>
